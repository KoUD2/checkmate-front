# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/checkmate?schema=public"

# JWT
JWT_SECRET="your_jwt_secret_min_32_characters_here_change_me"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_min_32_characters_here_change_me"

# App
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Gemini AI
GEMINI_API_KEY="your_gemini_api_key_here"

# YooKassa
YOOKASSA_SHOP_ID="your_shop_id"
YOOKASSA_SECRET_KEY="your_secret_key"
YOOKASSA_RETURN_URL="https://yourdomain.com/payment/success"

# Social OAuth (для бонуса 2 проверки)
VK_APP_ID="your_vk_app_id"
VK_APP_SECRET="your_vk_app_secret"
VK_REDIRECT_URI="https://yourdomain.com/api/auth/vk/callback"

YANDEX_CLIENT_ID="your_yandex_client_id"
YANDEX_CLIENT_SECRET="your_yandex_client_secret"
YANDEX_REDIRECT_URI="https://yourdomain.com/api/auth/yandex/callback"

TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# Frontend env (for docker-compose)
NEXT_PUBLIC_TELEGRAM_BOT_NAME="your_bot_username_without_@"
