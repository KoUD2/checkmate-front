generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  passwordHash       String
  firstName          String
  lastName           String
  organization       String?
  role               Role     @default(USER)
  isActive           Boolean  @default(true)
  freeChecksLeft     Int      @default(3)
  vkId               String?  @unique
  telegramId         String?  @unique
  yandexId           String?  @unique
  socialBonusGranted Boolean  @default(false)
  referralCode       String?  @unique
  referredByCode     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tasks           Task[]
  subscription    Subscription?
  refreshTokens   RefreshToken[]
  promoUsages     PromoUsage[]
  payments        Payment[]
  referralBonuses ReferralBonus[]  @relation("ReferrerBonuses")
  referredBonus   ReferralBonus?   @relation("RefereeBonuses")
  variantAttempts VariantAttempt[]

  @@map("users")
}

model ReferralBonus {
  id            String   @id @default(cuid())
  referrerId    String
  refereeId     String   @unique
  checksAwarded Int
  createdAt     DateTime @default(now())

  referrer User @relation("ReferrerBonuses", fields: [referrerId], references: [id], onDelete: Cascade)
  referee  User @relation("RefereeBonuses", fields: [refereeId], references: [id], onDelete: Cascade)

  @@map("referral_bonuses")
}

enum Role {
  USER
  ADMIN
}

model Task {
  id                  String      @id @default(uuid())
  type                TaskType
  userId              String
  taskDescription     String
  solution            String
  imageBase64         String?
  solutionImageBase64 String?
  image1Base64        String?
  image2Base64        String?
  audioBase64         String?
  transcription       String?
  k1                  Int?
  k2                  Int?
  k3                  Int?
  k4                  Int?
  k5                  Int?
  totalScore          Int?
  feedback            Json?
  comments            Json?
  userRating          UserRating?
  userComment         String?
  createdAt           DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("tasks")
}

enum TaskType {
  TASK37
  TASK38
  TASK39
  TASK40
  TASK41
  TASK42
}

enum UserRating {
  LIKE
  DISLIKE
}

model Subscription {
  id        String    @id @default(uuid())
  userId    String    @unique
  isActive  Boolean   @default(false)
  expiresAt DateTime?
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Payment {
  id          String        @id @default(uuid())
  userId      String
  yookassaId  String        @unique
  status      PaymentStatus @default(PENDING)
  amount      Decimal       @db.Decimal(10, 2)
  daysToAdd   Int
  checksToAdd Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  CANCELED
}

model PromoCode {
  id          String    @id @default(uuid())
  code        String    @unique
  days        Int
  description String?
  maxUses     Int?
  usedCount   Int       @default(0)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  usages PromoUsage[]

  @@map("promo_codes")
}

model PromoUsage {
  id      String   @id @default(uuid())
  promoId String
  userId  String
  usedAt  DateTime @default(now())

  promo PromoCode @relation(fields: [promoId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([promoId, userId])
  @@map("promo_usages")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model OAuthState {
  id           String   @id @default(uuid())
  userId       String
  provider     String
  codeVerifier String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("oauth_states")
}

model Resource {
  id             String       @id @default(cuid())
  slug           String       @unique
  type           ResourceType
  title          String
  description    String
  content        Json
  published      Boolean      @default(false)
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("resources")
}

enum ResourceType {
  ARTICLE
  CHECKLIST
  TRAINER
  TEMPLATE
}

model ExamTask {
  id            String      @id @default(uuid())
  format        TaskFormat
  section       ExamSection
  title         String
  body          String?
  audioUrl      String?
  correctAnswer String?
  source        String?
  explanation   String?
  aiTaskType    AiTaskType?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  options      ExamTaskOption[]
  variantTasks VariantTask[]

  @@map("exam_tasks")
}

model ExamTaskOption {
  id         String  @id @default(uuid())
  examTaskId String
  optionText String
  matchText  String?
  isCorrect  Boolean @default(false)

  examTask ExamTask @relation(fields: [examTaskId], references: [id], onDelete: Cascade)

  @@map("exam_task_options")
}

model Variant {
  id          String   @id @default(uuid())
  title       String
  description String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variantTasks    VariantTask[]
  variantAttempts VariantAttempt[]

  @@map("variants")
}

model VariantTask {
  id         String @id @default(uuid())
  variantId  String
  examTaskId String
  position   Float

  variant  Variant  @relation(fields: [variantId], references: [id], onDelete: Cascade)
  examTask ExamTask @relation(fields: [examTaskId], references: [id], onDelete: Restrict)

  @@unique([variantId, examTaskId])
  @@map("variant_tasks")
}

model VariantAttempt {
  id        String        @id @default(uuid())
  userId    String
  variantId String
  status    AttemptStatus @default(IN_PROGRESS)
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  updatedAt        DateTime      @updatedAt
  skippedSections  ExamSection[]

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant Variant         @relation(fields: [variantId], references: [id], onDelete: Restrict)
  answers AttemptAnswer[]

  @@map("variant_attempts")
}

model AttemptAnswer {
  id               String   @id @default(uuid())
  variantAttemptId String
  examTaskId       String
  content          Json?
  playCount        Int      @default(0)
  aiScore          Int?
  aiFeedback       Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  variantAttempt VariantAttempt @relation(fields: [variantAttemptId], references: [id], onDelete: Cascade)

  @@unique([variantAttemptId, examTaskId])
  @@map("attempt_answers")
}

enum TaskFormat {
  MCQ
  MATCHING
  TRUE_FALSE
  OPEN_CLOZE
  WORD_FORMATION
  AI_CHECK
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  COMPLETED
  FAILED
}

enum AiTaskType {
  TASK37
  TASK38
  TASK39
  TASK40
  TASK41
  TASK42
}

enum ExamSection {
  LISTENING
  READING
  GRAMMAR
  WRITING
  SPEAKING
}
